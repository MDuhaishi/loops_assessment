# ── Option A: Ollama (local, no API key needed) ────────────────────────────
# Set OLLAMA_MODE=true and ensure Ollama is running (ollama serve)
# Text model: any qwen model you have pulled (ollama list)
# Vision model: pull with: ollama pull qwen2.5vl:7b  (needed for PDF extraction)
OLLAMA_MODE=true
QWEN_TEXT_MODEL=qwen2.5:7b-instruct
QWEN_VISION_MODEL=qwen2.5vl:7b

# ── Option B: Alibaba DashScope API ────────────────────────────────────────
# Get your key at: https://dashscope.aliyuncs.com
# OLLAMA_MODE=false
# QWEN_API_KEY=
# QWEN_TEXT_MODEL=qwen-plus
# QWEN_VISION_MODEL=qwen-vl-plus

# ── Custom base URL (advanced) ──────────────────────────────────────────────
# Any OpenAI-compatible endpoint — overrides both options above
# QWEN_BASE_URL=http://localhost:11434/v1

# Server
PORT=3001
NODE_ENV=development
